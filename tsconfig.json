{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "include": [
    "src/**/*.ts",
    "src/**/*.js",
    "src/**/*.svelte",
    "packages/svelte-phaser/src/**/*.ts",
    "packages/svelte-phaser/src/**/*.svelte"
  ],
  "exclude": ["node_modules/*", "public/*", "docs/*"],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "types": ["svelte", "vite/client"],
    "skipLibCheck": true,
    "noEmit": true
  }
}
